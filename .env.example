# Backend
APP_ID=fitociencia-care-dev
APP_SECRET=replace-with-a-long-random-secret

# Local MySQL from docker-compose.yml
DATABASE_URL=mysql://fitociencia:fitociencia_dev_password@127.0.0.1:3307/fitociencia_care

# Frontend OAuth settings exposed by Vite
VITE_KIMI_AUTH_URL=
VITE_APP_ID=fitociencia-care-dev

# Backend OAuth settings
KIMI_AUTH_URL=
KIMI_OPEN_URL=

# First admin user
# Set this to your Kimi unionId before your first login, or update users.role manually.
OWNER_UNION_ID=
